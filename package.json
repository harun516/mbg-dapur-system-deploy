{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "pull:upstream": "powershell -ExecutionPolicy Bypass -File scripts/sync-upstream.ps1",
        "pull:upstream:merge": "powershell -ExecutionPolicy Bypass -File scripts/sync-upstream.ps1 -Strategy merge",
        "pull:upstream:rebase": "powershell -ExecutionPolicy Bypass -File scripts/sync-upstream.ps1 -Strategy rebase"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.1.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "sweetalert2": "^11.26.20"
    }
}
